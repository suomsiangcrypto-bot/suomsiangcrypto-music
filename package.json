{
  "name": "suomsiangcrypto-music",
  "version": "1.0.0",
  "description": "SUOMSIANGCRYPTO MUSIC Player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.suomsiangcrypto.music",
    "productName": "SUOMSIANGCRYPTO MUSIC",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.ico"
    },
    "portable": {
      "artifactName": "SUOMSIANGCRYPTO-MUSIC-Portable.exe"
    },
    "files": [
      "**/*",
      "!node_modules/**",
      "!dist/**",
      "!.github/**"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico",
      "installerHeader": "icons/icon256.png",
      "installerHeaderBackground": "#0d0b06",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SUOMSIANGCRYPTO MUSIC"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}